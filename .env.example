# Flussonic API (required)
FLUSSONIC_IP=192.168.1.10
FLUSSONIC_PORT=80
FLUSSONIC_USERNAME=admin
FLUSSONIC_PASSWORD=changeme

# Optional
FLUSSONIC_SERVER_ID=my-flussonic-1
# FLUSSONIC_SCHEME=https
# FLUSSONIC_HTTPS=false
FLUSSONIC_FETCH_INTERVAL=5
FLUSSONIC_TIMEOUT=5
FLUSSONIC_VERIFY_SSL=true

# Exporter
EXPORTER_PORT=9105
LOG_LEVEL=INFO

# Only used when using docker-compose with profile `monitoring`
# PROMETHEUS_PORT=9090
